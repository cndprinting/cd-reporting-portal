generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ACCOUNT_MANAGER
  CUSTOMER
}

enum CampaignStatus {
  DRAFT
  LIVE
  PAUSED
  COMPLETED
}

enum ChannelType {
  MAIL_TRACKING
  CALL_TRACKING
  GOOGLE_ADS
  FACEBOOK_ADS
  BEHAVIORAL_ADS
  GMAIL_ADS
  YOUTUBE_ADS
  QR_CODES
}

// -------- USPS IV-MTR / IMb tracking --------

enum MailPieceStatus {
  PENDING             // In mail file, not yet accepted by USPS
  ACCEPTED            // First scan received
  IN_TRANSIT          // Moving through network
  OUT_FOR_DELIVERY    // Loaded on carrier route
  DELIVERED           // Final delivery scan
  DELIVERED_INFERRED  // OFD + no bounce after 2 days, no final scan
  UNDELIVERABLE       // UAA / return to sender
}

enum ScanOperation {
  ORIGIN_ACCEPTANCE       // USPS accepted at origin facility
  ORIGIN_PROCESSED        // Sortation at origin
  IN_TRANSIT              // Between facilities
  DESTINATION_PROCESSED   // Sortation at destination SCF
  DESTINATION_DELIVERY    // At delivery unit
  OUT_FOR_DELIVERY        // Loaded for carrier
  DELIVERED               // Final delivery scan
  UNDELIVERABLE           // UAA
  OTHER
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           Role     @default(CUSTOMER)
  avatarUrl      String?
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  managedCompanies CompanyManager[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
  @@index([companyId])
}

model Company {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  logoUrl     String?
  website     String?
  address     String?
  phone       String?
  industry    String?
  isActive    Boolean    @default(true)
  users       User[]
  campaigns   Campaign[]
  managers    CompanyManager[]
  mailPieces  MailPiece[]
  apiKeys     ApiKey[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
}

model CompanyManager {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  campaignCode    String         @unique
  status          CampaignStatus @default(DRAFT)
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  description     String?
  destinationUrl  String?
  setupDate       DateTime       @default(now())
  startDate       DateTime?
  endDate         DateTime?
  previewImageUrl String?
  channels        CampaignChannel[]
  metrics         CampaignMetricDaily[]
  mailBatches     MailBatch[]
  qrMetrics       QRCodeMetric[]
  callLogs        CallLogSummary[]
  assets          Asset[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([campaignCode])
  @@index([status])
}

model CampaignChannel {
  id         String      @id @default(cuid())
  campaignId String
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    ChannelType
  isActive   Boolean     @default(true)
  budget     Float?
  notes      String?
  createdAt  DateTime    @default(now())

  @@unique([campaignId, channel])
}

model CampaignMetricDaily {
  id              String      @id @default(cuid())
  campaignId      String
  campaign        Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel         ChannelType
  date            DateTime    @db.Date
  impressions     Int         @default(0)
  clicks          Int         @default(0)
  leads           Int         @default(0)
  calls           Int         @default(0)
  qualifiedCalls  Int         @default(0)
  conversions     Int         @default(0)
  spend           Float       @default(0)
  piecesDelivered Int         @default(0)
  qrScans         Int         @default(0)

  @@unique([campaignId, channel, date])
  @@index([campaignId])
  @@index([date])
  @@index([channel])
}

model MailBatch {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  batchName       String
  quantity        Int
  dropDate        DateTime @db.Date
  expectedInHomeStart DateTime? @db.Date
  expectedInHomeEnd   DateTime? @db.Date
  mailClass       String?  // First-Class, Marketing Mail, etc.
  mailShape       String?  // letter, flat, parcel
  mailerId        String?  // MID used for this drop
  deliveredCount  Int      @default(0)
  returnedCount   Int      @default(0)
  inTransitCount  Int      @default(0)
  status          String   @default("pending")
  mailPieces      MailPiece[]
  createdAt       DateTime @default(now())

  @@index([campaignId])
  @@index([dropDate])
}

model MailPiece {
  id                  String          @id @default(cuid())
  campaignId          String
  campaign            Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // Denormalized for fast per-customer queries (set at import time from campaign.companyId)
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mailBatchId         String?
  mailBatch           MailBatch?      @relation(fields: [mailBatchId], references: [id], onDelete: SetNull)

  // USPS Intelligent Mail barcode (31 digits, DMM 708)
  imb                 String          @unique
  // Optional separate components for analytics
  imbBarcodeId        String?         // 2-digit barcode ID
  imbServiceType      String?         // 3-digit service type (STID)
  imbMailerId         String?         // 6 or 9-digit MID
  imbSerial           String?         // 6 or 9-digit serial number
  imbRoutingZip       String?         // 5/9/11-digit routing code

  // Recipient + address
  recipientName       String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  zip5                String?
  zip4                String?

  // Delivery prediction + status
  status              MailPieceStatus @default(PENDING)
  expectedInHomeDate  DateTime?       @db.Date
  firstScanAt         DateTime?
  lastScanAt          DateTime?
  deliveredAt         DateTime?
  daysToDeliver       Int?

  // Seed list flag (for QA / known-good addresses)
  isSeed              Boolean         @default(false)

  scanEvents          ScanEvent[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([campaignId])
  @@index([companyId])
  @@index([companyId, status])
  @@index([mailBatchId])
  @@index([imb])
  @@index([status])
  @@index([zip5])
  @@index([expectedInHomeDate])
}

model ScanEvent {
  id              String         @id @default(cuid())
  mailPieceId     String
  mailPiece       MailPiece      @relation(fields: [mailPieceId], references: [id], onDelete: Cascade)

  // Raw IMb from the feed (also stored on MailPiece for easy querying)
  imb             String
  scanDatetime    DateTime
  operation       ScanOperation  @default(OTHER)
  operationCode   String?        // USPS operation code (e.g., "92")
  operationDesc   String?        // Human description

  facilityZip     String?
  facilityCity    String?
  facilityState   String?
  facilityType    String?        // NDC, SCF, DDU, etc.

  machineId       String?
  runId           String?

  predictedDeliveryDate DateTime? @db.Date
  rawPayload      Json?

  // Dedup — USPS can deliver duplicates
  ingestionId     String?
  ingestion       IVFeedIngestion? @relation(fields: [ingestionId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())

  @@unique([imb, scanDatetime, operationCode, facilityZip])
  @@index([mailPieceId])
  @@index([imb])
  @@index([scanDatetime])
  @@index([operation])
}

model IVFeedIngestion {
  id              String           @id @default(cuid())
  source          String           // "iv-mtr-push", "iv-mtr-pull", "manual"
  fileName        String?
  fileSize        Int?
  recordsReceived Int              @default(0)
  recordsInserted Int              @default(0)
  recordsSkipped  Int              @default(0)
  status          IngestionStatus  @default(PENDING)
  errorMessage    String?
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  scanEvents      ScanEvent[]

  @@index([status])
  @@index([startedAt])
}

model QRCodeMetric {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  codeLabel  String
  scans      Int      @default(0)
  uniqueScans Int     @default(0)
  date       DateTime @db.Date
  createdAt  DateTime @default(now())

  @@index([campaignId])
}

model CallLogSummary {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  totalCalls     Int      @default(0)
  qualifiedCalls Int      @default(0)
  avgDuration    Int      @default(0)
  missedCalls    Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([campaignId])
}

model Asset {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  type       String
  url        String
  thumbnail  String?
  createdAt  DateTime @default(now())

  @@index([campaignId])
}

model InviteToken {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  role       Role      @default(CUSTOMER)
  companyId  String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model ApiKey {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String    // e.g. "Sunshine Realty production key"
  keyHash     String    @unique // sha256 of the raw key; raw key shown once at creation
  keyPrefix   String    // first 8 chars for display/lookup (e.g. "cdk_live_ab12cd34")
  scopes      String    @default("read:tracking") // space-separated scope list
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([keyPrefix])
}

model ReportExport {
  id         String   @id @default(cuid())
  userId     String
  companyId  String
  campaignId String?
  format     String   @default("csv")
  status     String   @default("pending")
  fileUrl    String?
  filters    String?
  createdAt  DateTime @default(now())
}
